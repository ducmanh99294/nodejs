

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Danh sách đặt chỗ</title>
</head>
<body class="bg-gray-100 min-h-screen flex flex-col items-center">
    <header class="bg-blue-500 text-white w-full py-4 text-center text-lg font-semibold">
        Danh sách đặt chỗ
    </header>
    <a href="/bookings/new"
    class="btn-create text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm w-full sm:w-auto px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">Create</a>
    <div class="container mx-auto my-6">
        <table class="w-full bg-white shadow-md rounded-lg overflow-hidden">
            <thead class="bg-gray-200">
                <tr>
                    <th class="py-2 px-4 text-left">Tên khách hàng</th>
                    <th class="py-2 px-4 text-left">Ngày</th>
                    <th class="py-2 px-4 text-left">Giờ</th>
                    <th class="py-2 px-4 text-left">Trạng thái</th>
                    <th class="py-2 px-4 text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                
                <!-- Một dòng mẫu -->
                <% booking.forEach((b)=>{ %>
                    <tr
                        class="odd:bg-white">
                        <th scope="row"
                            class="px-6 py-4 ">
                            <%= b.customName %>
                        </th>
                        <td class="px-6 py-4">
                            <%= b.date %>
                        </td>
                        <td class="px-6 py-4">
                            <%= b.time %>
                        </td>
                        <td class="px-6 py-4">
                            <span 
                                class="px-2 py-1 rounded text-white <%= b.role === 'Pending' ? 'bg-yellow-500' : b.role === 'Confirmed' ? 'bg-green-500' : 'bg-red-500' %>">
                                <%= b.role %>
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <a href="/bookings/edit"
                                class="font-medium text-blue-600 dark:text-blue-500 hover:underline">Edit</a>
                                <form method="post"
                                action="/bookings/delete/<%= b.id %>">
                                <input type="hidden" name="_method" value="DELETE">
                                <button type="submit" data-method="delete"
                                    class="font-medium text-blue-600 dark:text-blue-500 hover:underline color-red">delete</button>
                            </form>
                         </td>
                    </tr>
                    <%})%>
    
                <!-- Thêm các dòng khác -->
            </tbody>
        </table>
    </div>
</body>
</html>
